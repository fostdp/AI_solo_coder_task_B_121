# ================================
# 通用配置
# ================================
TZ=Asia/Shanghai
CONFIG_DIR=./config

# ================================
# Rust 后端配置
# ================================
HOST=0.0.0.0
PORT=8080
RUST_LOG=info,bridge_monitoring_backend=debug
RUST_BACKTRACE=1
CHANNEL_BUFFER=200

# ================================
# InfluxDB 配置
# ================================
INFLUXDB_URL=http://localhost:8086
INFLUXDB_DB=bridge_monitoring
INFLUXDB_USER=admin
INFLUXDB_PASS=admin123
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin123
INFLUXDB_HTTP_AUTH_ENABLED=true

# ================================
# MQTT 配置
# ================================
MQTT_ENABLED=true
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=bridge_monitor

# ================================
# 模拟器配置
# ================================
API_HOST=localhost
API_PORT=8080
SIM_INTERVAL=60

# ================================
# Prometheus 配置
# ================================
PROMETHEUS_PORT=9090

# ================================
# Grafana 配置
# ================================
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin123
